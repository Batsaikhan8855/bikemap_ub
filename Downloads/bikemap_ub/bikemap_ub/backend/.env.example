# ── Production -д заавал random утгаар сольж бичих ──────────────────────────────
# Random key үүсгэх:  python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-me-with-a-random-50-char-string

# ── Орчны тохиргоо ────────────────────────────────────────────────────────────
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,bikemap-ub.example.com

# ── PostgreSQL (хоосон орхивол SQLite ашиглана) ───────────────────────────────
# DATABASE_URL=postgres://user:password@localhost:5432/bikemap_db
DATABASE_URL=

# ── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ── OSRM (маршрут тооцоолол) — публик демо, production-д өөрөө host хий ───────
OSRM_BASE_URL=http://router.project-osrm.org

# ── Media ─────────────────────────────────────────────────────────────────────
MEDIA_ROOT=media/

# ── Security (production-д True) ──────────────────────────────────────────────
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
